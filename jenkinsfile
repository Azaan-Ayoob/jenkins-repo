pipeline{
    agent any 
    stages{
        stage("compile"){
            steps{
                bat 'javac Main.java'
            }
        }
        stage("run"){
            steps{
                bat 'java Main'
            }
        }
    }
    post {
        always {
            bat 'echo "Running Post Build Stages"'
        }
        success {
            bat 'echo "Build went successful"'
        }
        failure{
            bat 'echo "Failed to build project"'
        }
    }
}